<Window x:Class="E2ETest.RecordLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E2ETest 录制启动器" Width="780" Height="720" MinWidth="620" MinHeight="600"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="开始一次测试录制" FontSize="24" FontWeight="SemiBold" Foreground="#101828" />
            <TextBlock Text="填写测试用例信息后，由同目录的 e2etest.exe 执行录制。" Margin="0,5,0,0" Foreground="#667085" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="测试用例名称 *" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6" />
            <TextBox x:Name="NameBox" MaxLength="80" ToolTip="1～80 字符的合法 Windows 文件名" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="数据根目录" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="RootBox" VerticalContentAlignment="Center" />
                <Button Grid.Column="1" Content="选择..." Margin="8,0,0,0" Click="BrowseRoot_Click" />
            </Grid>
            <TextBlock x:Name="CliPathText" Margin="0,6,0,0" Foreground="#667085" TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="测试重点（可选）" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6" />
            <TextBox x:Name="FocusBox" MaxLength="4000" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" MinHeight="105" />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="样例判断标准（可选）" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,6" />
            <TextBox x:Name="CriteriaBox" MaxLength="4000" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" MinHeight="105" />
        </StackPanel>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#667085" Text="准备就绪" TextWrapping="Wrap" />
            <Button x:Name="StartButton" Grid.Column="1" Content="开始录制" MinWidth="130"
                    Background="#175CD3" Foreground="White" BorderBrush="#175CD3" FontWeight="SemiBold"
                    Click="StartRecording_Click" IsDefault="True" />
        </Grid>
    </Grid>
</Window>
