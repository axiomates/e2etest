<Window x:Class="E2ETest.ReportViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:E2ETest.ReportViewer"
        Title="E2ETest 报告分析" Width="1520" Height="900" MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="12">
    <Window.Resources>
        <local:VerdictTextConverter x:Key="VerdictText" />
        <local:VerdictBrushConverter x:Key="VerdictBrush" />
        <local:RoleTextConverter x:Key="RoleText" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Background" Value="#175CD3" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF2FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#101828" Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="E2ETest 报告分析" Foreground="White" FontSize="19" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock x:Name="OpenedPathText" Grid.Column="1" VerticalAlignment="Center" Margin="28,0"
                           Foreground="#D0D5DD" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="2" Content="打开报告目录" Click="OpenReports_Click" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}" Padding="12,9" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="当前轮次" Foreground="#667085" />
                    <ComboBox x:Name="RoundCombo" Margin="0,4,0,0" SelectionChanged="RoundCombo_SelectionChanged"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12,9" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="需要查看" Foreground="#667085" />
                    <TextBlock x:Name="AttentionCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#B54708" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="12,9" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="明确失败" Foreground="#667085" />
                    <TextBlock x:Name="FailedCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#B42318" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="12,9" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="已通过" Foreground="#667085" />
                    <TextBlock x:Name="PassedCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#067647" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="12,9">
                <StackPanel>
                    <TextBlock Text="全部用例" Foreground="#667085" />
                    <TextBlock x:Name="TotalCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#344054" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="255" MinWidth="220" MaxWidth="330" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="测试用例" FontSize="15" FontWeight="SemiBold" Foreground="#101828" />
                    <Grid Grid.Row="1" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="94"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="输入名称筛选" />
                        <ComboBox x:Name="FilterCombo" Grid.Column="1" Margin="8,0,0,0" SelectionChanged="FilterCombo_SelectionChanged" />
                    </Grid>
                    <ListBox x:Name="CaseList" Grid.Row="2" BorderThickness="0" Background="Transparent"
                             SelectionChanged="CaseList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="9" Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#101828" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Background="{Binding FinalVerdict, Converter={StaticResource VerdictBrush}}" CornerRadius="10" Padding="8,2">
                                                <TextBlock Text="{Binding FinalVerdict, Converter={StaticResource VerdictText}}" Foreground="White" FontSize="11" />
                                            </Border>
                                        </Grid>
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Foreground="#667085">
                                                <Run Text="关注 " /><Run Text="{Binding AttentionLevel}" /><Run Text="  ·  " /><Run Text="{Binding AttentionScore}" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Ai.Status}" Foreground="#667085" FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="Transparent" HorizontalAlignment="Stretch" />

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid x:Name="DetailRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border x:Name="CaseBanner" Padding="14,10" Background="#F9FAFB" BorderBrush="#E4E7EC" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="CaseNameText" FontSize="18" FontWeight="SemiBold" Foreground="#101828" />
                                <TextBlock x:Name="CaseGuidanceText" Margin="0,3,0,0" Foreground="#475467" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Border x:Name="CaseVerdictBadge" CornerRadius="12" Padding="10,3" HorizontalAlignment="Right">
                                    <TextBlock x:Name="CaseVerdictText" Foreground="White" FontWeight="SemiBold" />
                                </Border>
                                <TextBlock x:Name="LocalFinalText" Foreground="#667085" Margin="0,4,0,0" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="215" MinWidth="185" MaxWidth="280" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#E4E7EC" BorderThickness="0,0,1,0" Padding="9">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Text="流程步骤" FontSize="14" FontWeight="SemiBold" Foreground="#101828" Margin="0,0,0,8" />
                                <ListBox x:Name="ShotList" Grid.Row="1" BorderThickness="0" Background="Transparent" SelectionChanged="ShotList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="8" Padding="8" Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Foreground="#101828"><Run Text="步骤 "/><Run Text="{Binding Ordinal}"/></TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding FinalVerdict, Converter={StaticResource VerdictText}}" Foreground="{Binding FinalVerdict, Converter={StaticResource VerdictBrush}}" FontWeight="SemiBold" />
                                                    </Grid>
                                                    <TextBlock Foreground="#667085" FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Role, Converter={StaticResource RoleText}}"/><Run Text="  ·  差异 "/><Run Text="{Binding Pixel.ChangedPixels}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="6" Background="Transparent" HorizontalAlignment="Stretch" />

                        <Grid Grid.Column="2" Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="ShotTitleText" FontSize="16" FontWeight="SemiBold" Foreground="#101828" />
                                        <TextBlock x:Name="ShotMetaText" Foreground="#667085" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="ExactMatchBadge" Background="#067647" CornerRadius="12" Padding="10,4" Visibility="Collapsed">
                                            <TextBlock Text="完全一致" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                        <ComboBox x:Name="EvidenceModeCombo" Width="132" DisplayMemberPath="Label" SelectionChanged="EvidenceModeCombo_SelectionChanged" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel x:Name="RegionPanel" Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock x:Name="RegionHeadingText" Text="差异区域" FontWeight="SemiBold" Foreground="#344054" Margin="0,0,0,4" />
                                    <ListBox x:Name="RegionList" SelectionChanged="RegionList_SelectionChanged" BorderThickness="0" Background="Transparent"
                                             PreviewMouseWheel="RegionList_PreviewMouseWheel" ToolTip="区域较多时可使用鼠标滚轮逐个切换"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Padding="9,3" Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}">
                                                    <TextBlock><Run Text="{Binding Id}"/><Run Text="  ·  "/><Run Text="{Binding ChangedPixels}"/></TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="280" />
                                        <ColumnDefinition x:Name="AiGapColumn" Width="10" />
                                        <ColumnDefinition x:Name="AiColumn" Width="280" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Style="{StaticResource Card}" Background="#EAECF0" Padding="6">
                                            <Grid>
                                                <Image x:Name="EvidenceImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                                <Grid x:Name="VerticalComparisonGrid" Visibility="Collapsed">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,3">
                                                        <Image x:Name="BaselineComparisonImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <Border Background="#CC101828" Padding="7,3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5">
                                                            <TextBlock Text="基准" Foreground="White" FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                    <Grid Grid.Row="1" Margin="0,3,0,0">
                                                        <Image x:Name="ReplayComparisonImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                                        <Border Background="#CC175CD3" Padding="7,3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5">
                                                            <TextBlock Text="回放" Foreground="White" FontWeight="SemiBold" />
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                                <TextBlock x:Name="ImageEmptyText" Text="没有可显示的证据图" Foreground="#667085" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Row="1" Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock x:Name="EvidencePathText" Foreground="#667085" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="打开图片" Margin="6,0,0,0" Padding="10,6" Click="OpenImage_Click" />
                                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="定位文件" Margin="6,0,0,0" Padding="10,6" Click="RevealImage_Click" />
                                        </Grid>
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border x:Name="AiPanel" Style="{StaticResource Card}" Padding="12">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="AI 复核" FontSize="14" FontWeight="SemiBold" Foreground="#101828" />
                                                    <TextBlock x:Name="AiConfidenceText" Grid.Column="1" Foreground="#667085" />
                                                </Grid>
                                                <TextBlock Text="看到了什么" Foreground="#667085" Margin="0,9,0,3" />
                                                <TextBlock x:Name="AiObservationText" TextWrapping="Wrap" Foreground="#101828" LineHeight="19" />
                                                <TextBlock Text="为什么这样判断" Foreground="#667085" Margin="0,9,0,3" />
                                                <TextBlock x:Name="AiReasonText" TextWrapping="Wrap" Foreground="#101828" LineHeight="19" />
                                            </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <Border x:Name="ErrorPanel" Grid.Row="1" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="10" BorderBrush="#FDA29B" Background="#FEF3F2">
                                            <StackPanel>
                                                <TextBlock Text="技术信息" FontWeight="SemiBold" Foreground="#B42318" />
                                                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#7A271A" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
